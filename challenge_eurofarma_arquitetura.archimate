  <folder name="Motivation" id="id-6672297c50364921b5e6f3e5952ed952" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Eurofarma" id="id-6ea993fceeab4af48aa436663b789883"/>
    <element xsi:type="archimate:Driver" name="Conectar nutrizes aos bancos de leite de forma simples, digital e eficiente, aumentando o número de doações" id="id-b579eff246774818a46cfe49f1b080de"/>
    <element xsi:type="archimate:Goal" name="Comunicação com o cliente demandante epara feedbacks" id="id-9d41d0a376aa4c9e8494768c6c880a58"/>
    <element xsi:type="archimate:Goal" name="Facilitar o acesso à informação sobre o projeto" id="id-e274d32cd9f14d94869edc1600761b46"/>
    <element xsi:type="archimate:Outcome" name="Entender a experiência da nutriz e melhorar continuamente o processo de doação" id="id-fdbb1a0be7fc4e0aa077ec3df3745df2"/>
    <element xsi:type="archimate:Goal" name="Entender a experiência da nutriz e melhorar continuamente o processo de doação" id="id-0e003815930a47f5abb79e2ecbfc5cdb"/>
    <element xsi:type="archimate:Outcome" name="Garantir 100% que todas as nutrizes sejam ouvidas através de um feedback após o processo de doação" id="id-4de19e01af074bd88ba704e9e042b6e2"/>
    <element xsi:type="archimate:Outcome" name="Outcome" id="id-37b758fcfb9847dbb2ff90c1ae4cfaaf"/>
    <element xsi:type="archimate:Outcome" name="Aumentar o nível de satisfação das nutrizes de forma gradual, a partir da implementação da solução" id="id-b985f4ab05b947678325eabb481c6b2f"/>
    <element xsi:type="archimate:Principle" name="Pesquisa de satisfação" id="id-9aaa84c997344854a94072408a1533e4"/>
    <element xsi:type="archimate:Principle" id="id-1114f46ae3b74bee8794b890aa2b1717"/>
    <element xsi:type="archimate:Outcome" name="Inserir QR codes em produtos infantis da Eurofarma oara direcionar nutrizes a conteúdos e canais de doação" id="id-355c0237a5f84af9ad71c5c7ab56ac63"/>
