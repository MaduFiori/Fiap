  <folder name="Strategy" id="id-737d4e887162492bb00521bc9043b41f" type="strategy"/>
  <folder name="Business" id="id-a376e4af2abd4672b91703546115a1fd" type="business"/>
  <folder name="Application" id="id-14e35c96d2f64c6d9f0b6dc97f95e9bb" type="application"/>
  <folder name="Technology &amp; Physical" id="id-0f1e883bd45e4ff1b21959170335c139" type="technology"/>
  <folder name="Motivation" id="id-1dd82fa1686a43eea04d91d366d1f5a1" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Dono da software house" id="id-65b404f56fb541ec9f0abd631b0dc27b"/>
    <element xsi:type="archimate:Driver" name="Formalização e controle administrativo sobre atividades de suporte técnico" id="id-7be3063642de48299118e07a1ba67284"/>
    <element xsi:type="archimate:Principle" name="Fazer registro formal de chamados técnicos" id="id-b4726badd47d41ffa8a419fe68c1c6d1"/>
    <element xsi:type="archimate:Principle" name="Controlar tempo de atendimento de cada chamado" id="id-c20f15623a1940ae920ddd5404ffcdfa"/>
    <element xsi:type="archimate:Principle" name="Medir a satisfação dos clientes" id="id-5538f4a2d15746acb199cf8cf791e4f5"/>
    <element xsi:type="archimate:Goal" name="Workflow do fluxo de atendimento de chamados " id="id-eac093237ab54bca90012d1aa997e797"/>
    <element xsi:type="archimate:Goal" name="Comunicação com o cliente demandante para feedbacks" id="id-d4f8a8a9c0e34d5bab590916f2a4a4cf"/>
    <element xsi:type="archimate:Goal" name="Gerar consultas, relatórios, dashboards de acompanhamento de desempenho do suporte" id="id-07940db2f5694cce926259fe9109ee4d"/>
    <element xsi:type="archimate:Assessment" name="Workflow digitalizado com apoio da IA em cada etapa do processo" id="id-3e7ca02d0450459b91ef0fefc0a8992f"/>
    <element xsi:type="archimate:Assessment" name="Usar um sistema de comunicação instantânea digital e público" id="id-e1e6b1257d8342dd914276894f555cc1"/>
    <element xsi:type="archimate:Assessment" name="Usar solução de BI de mercado" id="id-8e66caa2c2d546c9a291f3454868860a"/>
    <element xsi:type="archimate:Assessment" name="Usar solução de BI de mercado (copy)" id="id-369abe24281f4d61a309e31309a91f2b"/>
    <element xsi:type="archimate:Outcome" name="Aumentar o nível de satisfação dos clientes de forma gradual, a partir da implantação da solução" id="id-ad109c6380a94d3883c09de3f01b2f87"/>
    <element xsi:type="archimate:Outcome" name="Garantir que 100% dos chamados resolvidos tenham uma pesquisa de satisfação" id="id-5ed9c9f319f348ff9ed38ff71d8cd6f4"/>
    <element xsi:type="archimate:Outcome" name="100% dos atendimentos de supoorte registrados no sistema de informação disponibilizado" id="id-32d4757cb8894d24a87e350542e99cb8"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-511e4e0f457d4a6e879366dada5d2f00"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-bcd99e34fe314390a2a728eb6d587cf8"/>
    <element xsi:type="archimate:Requirement" name="Registrar novo chamado" id="id-90796626966a4a359db74023970cfa9b"/>
    <element xsi:type="archimate:Requirement" name="Triagem de chamados para encaminhamento" id="id-f692e3146dec4ab3ae4e752cbfc28a0f"/>
    <element xsi:type="archimate:Requirement" name="Registrar log de ação realizada no atendimento" id="id-e4eaa2dfb42144dfa9772ffa1aec1439"/>
    <element xsi:type="archimate:Requirement" name="Registrar solução para o problema diagnosticado" id="id-073ef770afb043bda153f74acea07d57"/>
    <element xsi:type="archimate:Constraint" name="Deve ser informado pelo usuário a identificação do cliente, descrição do problema. O sistema deve gerar um número de protocolo de registro do chamado com a data e hora de abertura e a identificação do analista de suporte que fez o contato, atribuindo o status pendente" id="id-5a45f7d3c6e24061ad1d10ff8db55a95"/>
    <element xsi:type="archimate:Constraint" name="Um analista do suporte N1 deve avaliar os chamados que estão pendentes e estão sem triagem e apontar um analista, atualizando os dados do chamado" id="id-93fd8e2b31864e00a094de33e15d0930"/>
    <element xsi:type="archimate:Constraint" name="Um analista de uma equipe técnica o 1 chamado pendente da fila atribuida à sua especialidade e vai registrar a ação que tomou para tentar solucionar o caso e o sistema vai registrar um log com os dados de identificação do analista, ação realizada, data e hora da operação" id="id-4ece3845c9e1453b875d538040cd3023"/>
    <element xsi:type="archimate:Constraint" name="O analista de suporte que solucionou o probelma de um chamado  deve descrever o diagnostico e a solução aplicada. O sistema deve atualizar o status do chamado para fechado, guardando no chamado o diagnostico e a solução. Além disso, o sistema deve alimentar a base de dados de soluções conhecidas com a descrição do problema, o diagnostiico e a solução. A data e hora das operações será guardada também em cada registro" id="id-4f07927f462e4634bd5e537450e7ecf7"/>
    <element xsi:type="archimate:Requirement" name="Disparar pesquisa de satisfação" id="id-aa7618a3d29a48d4a5414df74a59c64f"/>
    <element xsi:type="archimate:Constraint" name="Coletar e guardar a resposta da pesquisa" id="id-a25dbdd5a4324886ad48185b3460654c"/>
    <element xsi:type="archimate:Requirement" name="Coletar e guardar a resposta da pesquisa" id="id-e2bc0e2215d64d42a202b0fdf950ef3e"/>
    <element xsi:type="archimate:Constraint" name="A mensagem deve conter um texto padrão explicando o objetivo da pesquisa, identificar o numero do chamado e a descrição do problema original, acompanhado de uma lista de perguntas com opções de respostas pré configuradas" id="id-afbf74adb0d24971a9b60a1de242650b"/>
    <element xsi:type="archimate:Constraint" name="Deve ser coletadas as respostas e guardar os seguintes dados: identificação do cliente, número do chamado,identificação da pergunta e resposta da pergunta. Esses dados serão inseridos no banco de dados transacionais do suporte para uso em consultas" id="id-f7bc24f7589447a38032b3f218fe3c90"/>
    <element xsi:type="archimate:Requirement" name="Disponibilizar dados transacionais do suporte em um banco de dados data Mart/DW" id="id-6b68f467bb994370828e8fc33944e5f4"/>
    <element xsi:type="archimate:Constraint" name="Construir uma aplicação ETL para ler a base de dados transacionais do suporte e alimentar um banco de dados de consulta DW/ data mart" id="id-f473953e38804711b1c3329bb4575240"/>
  </folder>
